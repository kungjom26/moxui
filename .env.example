# MoxUI environment variables
#
# All variables are prefixed with MOXUI_
# Copy to .env (NOT committed) and edit

# Server bind address
MOXUI_BIND=0.0.0.0:8080

# Database path (SQLite)
MOXUI_DB_PATH=/home/moxui/data/moxui.db

# Logging
MOXUI_LOG_LEVEL=info          # trace|debug|info|warn|error
MOXUI_LOG_FORMAT=pretty       # pretty|json

# JWT signing key (RS256)
# Generate with: openssl genrsa -out jwt-private.pem 2048 && openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Or use the helper: scripts/gen-jwt-keys.sh
MOXUI_JWT_PRIVATE_KEY_PATH=/etc/moxui/jwt-private.pem
MOXUI_JWT_PUBLIC_KEY_PATH=/etc/moxui/jwt-public.pem
MOXUI_JWT_ISSUER=moxui
MOXUI_JWT_AUDIENCE=moxui-api

# Master encryption key (for cluster passwords, TOTP secrets)
# Generate with: openssl rand -base64 32
MOXUI_MASTER_KEY=replace-me-with-32-bytes-base64-encoded

# Proxmox clusters (JSON array, see config.example.yaml)
# MOXUI_CLUSTERS=[{"name":"homelab","url":"https://pve11.local:8006","username":"root@pam","password":"***"}]

# Bootstrap admin (used on first boot if no users exist)
MOXUI_ADMIN_USERNAME=admin
MOXUI_ADMIN_PASSWORD=change-me-on-first-login!

# Runtime
RUST_LOG=info
RUST_BACKTRACE=1