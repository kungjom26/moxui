# MoxUI environment variables
#
# All variables are prefixed with MOXUI_
# Use double-underscore __ to descend into nested config keys:
#   MOXUI_SERVER__BIND=0.0.0.0:9090
#   MOXUI_DATABASE__PATH=/var/lib/moxui/moxui.db
#   MOXUI_LOGGING__LEVEL=debug
#
# Copy to .env (NOT committed) and edit
# Or set via Docker / systemd / K8s env section

# ---- Server ----
MOXUI_SERVER__BIND=0.0.0.0:8080
MOXUI_SERVER__WORKERS=0           # 0 = num CPUs

# ---- Database ----
MOXUI_DATABASE__PATH=/var/lib/moxui/moxui.db
MOXUI_DATABASE__MAX_CONNECTIONS=8
MOXUI_DATABASE__RUN_MIGRATIONS=true

# ---- Logging ----
MOXUI_LOGGING__LEVEL=info         # trace|debug|info|warn|error
MOXUI_LOGGING__FORMAT=pretty      # pretty|json

# ---- Proxmox clusters (one env var per cluster) ----
# The standard way to inject credentials is via env vars, since the YAML
# config file would otherwise contain plaintext passwords.
#
# MoxUI does NOT support a flat MOXUI_CLUSTERS=... JSON var (the YAML
# loader is the only path for multi-cluster arrays). Configure clusters in
# /etc/moxui/config.yaml and inject the password via env var expansion
# (YAML supports ${VAR} substitution via figment's Env, or your secret
# manager of choice).
#
# If you'd rather pass an entire cluster block as JSON, you can:
#   1. Mount a config.yaml from a secret manager (K8s Secret / Vault / etc.)
#   2. Use MOXUI_CONFIG=/path/to/secret-managed-config.yaml to point at it

# ---- Runtime ----
RUST_LOG=info
RUST_BACKTRACE=1
